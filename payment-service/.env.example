# ============================================================
# SuviX Payment Service — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git. Only commit .env.example

# ---- Server ----
SERVER_PORT=8080

# ---- MongoDB (same Atlas URI as your Node server) ----
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/suvix?retryWrites=true&w=majority

# ---- Razorpay (same keys from your Node server .env) ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Confluent Cloud Kafka ----
# Get from: Confluent Cloud → Cluster → API Keys
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.ap-south-1.aws.confluent.cloud:9092
KAFKA_API_KEY=XXXXXXXXXXXXXXXXXX
KAFKA_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---- Service-to-Service Security ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be the SAME value in your Node server .env
SERVICE_SECRET=your_random_64_char_hex_string_here
