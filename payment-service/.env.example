# ============================================================
# payment-service/.env.example — Template for credentials
# Copy this to .env and fill in your values
# .env is gitignored — never commit it!
# ============================================================

# ──── Common (all profiles) ──────────────────────────────────
SERVER_PORT=8080
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB=suvix
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
SERVICE_SECRET=generate_with_node_-e_crypto.randomBytes(32).toString('hex')

# ──── Profile: local (Docker Kafka) ──────────────────────────
# No extra vars needed — uses localhost:9092 automatically
# Run: mvn spring-boot:run -Dspring-boot.run.profiles=local

# ──── Profile: upstash (Free, no Visa card) ──────────────────
# Sign up: console.upstash.com (Google login, no card)
# Run: mvn spring-boot:run -Dspring-boot.run.profiles=upstash
# On Render: set SPRING_PROFILES_ACTIVE=upstash
KAFKA_BOOTSTRAP_SERVERS=caring-condor-xxxxx-ap1-kafka.upstash.io:9092
KAFKA_API_KEY=your_upstash_username
KAFKA_API_SECRET=your_upstash_password

# ──── Profile: cloud (Confluent — production/paid) ────────────
# Sign up: confluent.cloud (needs Visa card)
# Run: mvn spring-boot:run -Dspring-boot.run.profiles=cloud
# On Render: set SPRING_PROFILES_ACTIVE=cloud
# KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.ap-south-1.aws.confluent.cloud:9092
# KAFKA_API_KEY=your_confluent_api_key
# KAFKA_API_SECRET=your_confluent_api_secret
