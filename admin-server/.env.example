# Server Environment Variables Template
# Copy this to .env and add your actual values

MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
NODE_ENV=development

# Authentication
GOOGLE_CLIENT_ID=your_google_oauth_id
GOOGLE_CLIENT_SECRET=your_google_oauth_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Firebase (Optional)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_bucket_url
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY=your_private_key

# Payment & Service Auth
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
PAYMENT_SERVICE_URL=http://localhost:8080
SERVICE_SECRET=your_shared_service_secret

# Kafka
KAFKA_BROKER=localhost:9092
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_API_KEY=
KAFKA_API_SECRET=

# URLs
FRONTEND_URL=http://localhost:5173
ADMIN_URL=https://adminsuvix.vercel.app

# ─── Redis (Upstash) ──────────────────────────────────────────
# Required — get from: console.upstash.com → Redis → REST API
REDIS_URL=https://your-redis-url.upstash.io
REDIS_TOKEN=your_redis_rest_token
