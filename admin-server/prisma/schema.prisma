// Admin Server - Modular Production Schema (Merged with Marketplace)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// MARKETPLACE MODELS (Merged from server)
// ==========================================

model User {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username               String?         @unique @db.VarChar(100)
  email                  String          @unique @db.VarChar(255)
  password_hash          String?         @map("password_hash")
  role                   UserRole        @default(suvix_user)
  auth_provider          AuthProvider?   @default(local) @map("auth_provider")
  google_id              String?         @unique @map("google_id") @db.VarChar(255)
  is_verified            Boolean         @default(false) @map("is_verified")
  is_banned              Boolean         @default(false) @map("is_banned")
  ban_reason             String?         @map("ban_reason")
  is_onboarded           Boolean         @default(false) @map("is_onboarded")
  token_version          Int             @default(0) @map("token_version")
  created_at             DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at             DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  received_messages      Message[]       @relation("MessageReceiver")
  sent_messages          Message[]       @relation("MessageSender")
  triggeredNotifications Notification[]  @relation("TriggeredNotifications")
  notifications          Notification[]  @relation("UserNotifications")
  pushTokens             PushToken[]
  follows                UserFollow[]    @relation("Follower")
  following              UserFollow[]    @relation("Following")
  profile                UserProfile?
  stats                  UserStats?
  youtubeProfiles        YouTubeProfile[]
  youtube_videos         YouTubeVideo[]
  posts                  Post[]
  media                  Media[]
  stories                Story[]
  story_views            StoryView[]

  @@index([role])
  @@index([is_onboarded])
  @@map("users")
}

model UserProfile {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String             @unique @map("user_id") @db.Uuid
  username          String             @unique @db.VarChar(100)
  name              String             @db.VarChar(100)
  profile_picture   String?            @map("profile_picture")
  bio               String?
  mother_tongue     String?            @map("mother_tongue") @db.VarChar(50)
  auth_provider     AuthProvider?      @default(local) @map("auth_provider")
  location_city     String?            @map("location_city") @db.VarChar(100)
  location_state    String?            @map("location_state") @db.VarChar(100)
  location_country  String?            @default("India") @map("location_country") @db.VarChar(100)
  phone             String?            @db.VarChar(20)
  is_phone_verified Boolean            @default(false) @map("is_phone_verified")
  availability      AvailabilityStatus @default(available)
  categoryId        String?            @map("role_category_id") @db.Uuid
  created_at        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at        DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  category          RoleCategory?      @relation(fields: [categoryId], references: [id])
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles             UserRoleMapping[]

  @@index([categoryId])
  @@map("user_profiles")
}

model UserFollow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  created_at  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("user_follows")
}

model RoleCategory {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String            @db.VarChar(100)
  slug          String            @unique @db.VarChar(100)
  icon          String?           @db.VarChar(50)
  roleGroup     RoleGroup         @default(PROVIDER) @map("role_group")
  description   String?
  info          String?
  subCategories RoleSubCategory[]
  profiles      UserProfile[]

  @@map("role_categories")
}

model RoleSubCategory {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleCategoryId String            @map("role_category_id") @db.Uuid
  name           String            @db.VarChar(100)
  slug           String            @db.VarChar(100)
  category       RoleCategory      @relation(fields: [roleCategoryId], references: [id], onDelete: Cascade)
  userRoles      UserRoleMapping[]
  youtubeProfiles YouTubeProfile[]

  @@unique([roleCategoryId, slug])
  @@map("role_sub_categories")
}

model UserRoleMapping {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId         String          @map("profile_id") @db.Uuid
  roleSubCategoryId String          @map("role_sub_category_id") @db.Uuid
  isPrimary         Boolean         @default(false) @map("is_primary")
  profile           UserProfile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subCategory       RoleSubCategory @relation(fields: [roleSubCategoryId], references: [id], onDelete: Cascade)

  @@unique([profileId, roleSubCategoryId])
  @@index([profileId, isPrimary])
  @@map("user_role_mappings")
}

model UserStats {
  userId          String   @id @map("user_id") @db.Uuid
  followers_count Int      @default(0)
  following_count Int      @default(0)
  created_at      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model YouTubeProfile {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String           @map("user_id") @db.Uuid
  is_primary          Boolean          @default(false)
  channel_id          String           @unique @db.VarChar(255)
  channel_name        String           @db.VarChar(255)
  subscriber_count    Int?             @default(0)
  video_count         Int?             @default(0)
  thumbnail_url       String?
  connected_at        DateTime         @default(now()) @map("connected_at") @db.Timestamptz(6)
  created_at          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at          DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  last_synced_at      DateTime?        @map("last_synced_at") @db.Timestamptz(6)
  uploads_playlist_id String?          @map("uploads_playlist_id") @db.VarChar(255)
  video_cache_count   Int              @default(0) @map("video_cache_count")
  subCategoryId       String?          @map("sub_category_id") @db.Uuid
  language            String?          @db.VarChar(50)
  
  subCategory         RoleSubCategory? @relation(fields: [subCategoryId], references: [id])
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sync_logs           YouTubeSyncLog[]
  videos              YouTubeVideo[]

  @@map("youtube_profiles")
}

model YouTubeVideo {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String?        @db.Uuid
  channel_id       String         @db.VarChar(255)
  video_id         String         @unique @db.VarChar(100)
  title            String         @db.VarChar(500)
  description      String?        @db.Text
  tags             String?        @db.Text
  thumbnail        String?
  duration_secs    Int?
  view_count       BigInt?        @default(0)
  published_at     DateTime?      @map("published_at") @db.Timestamptz(6)
  created_at       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at       DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  is_latest        Boolean        @default(true)
  position         Int?           @default(0)
  youtubeProfileId String         @map("youtube_profile_id") @db.Uuid
  user             User?          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  youtubeProfile   YouTubeProfile @relation(fields: [youtubeProfileId], references: [id], onDelete: Cascade)

  @@index([channel_id])
  @@index([youtubeProfileId, published_at])
  @@map("youtube_videos")
}

model YouTubeSearchDictionary {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  term             String   @unique @db.VarChar(500)
  type             String   @default("VIDEO_TITLE") // VIDEO_TITLE, CHANNEL_NAME, KEYWORD
  popularity_score Int      @default(0)
  is_trending      Boolean  @default(false)
  last_used_at     DateTime @default(now()) @map("last_used_at")
  created_at       DateTime @default(now()) @map("created_at")

  @@index([term])
  @@index([popularity_score])
  @@map("youtube_search_dictionary")
}

model YouTubeSyncLog {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  youtubeProfileId String         @map("youtube_profile_id") @db.Uuid
  lastSyncedAt     DateTime       @default(now()) @map("last_synced_at") @db.Timestamptz(6)
  status           String         @db.VarChar(20)
  error_message    String?
  youtubeProfile   YouTubeProfile @relation(fields: [youtubeProfileId], references: [id], onDelete: Cascade)

  @@index([youtubeProfileId])
  @@map("youtube_sync_logs")
}

model Notification {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String               @map("user_id") @db.Uuid
  senderId   String?              @map("sender_id") @db.Uuid
  type       NotificationType
  priority   NotificationPriority @default(NORMAL)
  entityId   String?              @map("entity_id")
  entityType String?              @map("entity_type")
  title      String               @db.VarChar(255)
  body       String
  image_url  String?              @map("image_url")
  metadata   Json?                @default("{}")
  is_sent    Boolean              @default(false)
  is_read    Boolean              @default(false)
  read_at    DateTime?            @map("read_at")
  is_deleted Boolean              @default(false)
  created_at DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  sender     User?                @relation("TriggeredNotifications", fields: [senderId], references: [id])
  user       User                 @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, created_at])
  @@index([userId, is_read])
  @@index([entityId, entityType])
  @@map("notifications")
}

model PushToken {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  token        String   @unique
  platform     Platform @default(ANDROID)
  device_name  String?  @map("device_name")
  is_active    Boolean  @default(true)
  last_error   String?  @map("last_error")
  last_used_at DateTime @default(now()) @map("last_used_at")
  created_at   DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model Message {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id   String   @map("sender_id") @db.Uuid
  receiver_id String   @map("receiver_id") @db.Uuid
  type        String   @default("text") @db.VarChar(20)
  content     String
  is_read     Boolean  @default(false) @map("is_read")
  created_at  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  receiver    User     @relation("MessageReceiver", fields: [receiver_id], references: [id])
  sender      User     @relation("MessageSender", fields: [sender_id], references: [id])

  @@index([sender_id])
  @@index([receiver_id])
  @@map("messages")
}

model Post {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  caption     String?    @db.Text
  type        PostType   @default(IMAGE)
  isReel      Boolean    @default(false) @map("is_reel")
  visibility  Visibility @default(PUBLIC)
  created_at  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  media       Media[]

  @@index([userId, created_at])
  @@map("posts")
}

model Media {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId      String?     @map("post_id") @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  type        MediaType   @default(IMAGE)
  storageKey  String      @map("storage_key")
  mimeType    String?     @map("mime_type")
  size        Int?
  width       Int?
  height      Int?
  duration    Int?
  variants    Json?
  blurhash    String?
  hash        String?     @db.VarChar(64)
  status           MediaStatus @default(PENDING)
  storage_provider String      @default("S3") @map("storage_provider")
  created_at       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  post        Post?       @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  story       Story?

  @@index([postId])
  @@index([userId])
  @@map("media")
}

model Story {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  mediaId     String   @unique @map("media_id") @db.Uuid
  caption     String?  @db.Text
  expires_at  DateTime @map("expires_at") @db.Timestamptz(6)
  is_archived Boolean  @default(false) @map("is_archived")
  view_count  Int      @default(0) @map("view_count")
  visibility  Visibility @default(PUBLIC)
  metadata    Json?      @default("{}")
  created_at  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  views StoryView[]

  @@index([userId, expires_at])
  @@index([expires_at])
  @@map("stories")
}

model StoryView {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storyId   String   @map("story_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  viewed_at DateTime @default(now()) @map("viewed_at") @db.Timestamptz(6)

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@map("story_views")
}

// ==========================================
// ADMIN MODELS (Newly Added)
// ==========================================

model AdminRole {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(100)
  value           String   @unique @db.VarChar(50)
  description     String?  @default("")
  color           String?  @default("#1d4ed8") @db.VarChar(20)
  permissions     Json     @default("{}")
  is_active       Boolean? @default(true) @map("is_active")
  is_system       Boolean? @default(false) @map("is_system")
  member_count    Int?     @default(0) @map("member_count")
  created_at      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  members         AdminMember[]

  @@map("admin_roles")
}

model AdminMember {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String   @unique @db.VarChar(255)
  password_hash           String    @map("password_hash")
  password                String?   @db.VarChar(255) // Migration field or alias
  name                    String   @db.VarChar(100)
  role_id                 String?  @map("role_id") @db.Uuid
  role_value              String?  @default("admin") @map("role_value") @db.VarChar(50)
  profile_image           String?  @map("profile_image")
  permissions             Json?    @default("{}")
  is_active               Boolean? @default(true) @map("is_active")
  last_login              DateTime? @map("last_login") @db.Timestamptz(6)
  last_login_ip           String?  @map("last_login_ip") @db.Inet
  login_attempts          Int?     @default(0) @map("login_attempts") @db.SmallInt
  locked_until            DateTime? @map("locked_until") @db.Timestamptz(6)
  current_session_token   String?  @map("current_session_token")
  password_reset_token    String?  @map("password_reset_token")
  password_reset_expires  DateTime? @map("password_reset_expires") @db.Timestamptz(6)
  password_changed_at     DateTime? @map("password_changed_at") @db.Timestamptz(6)
  notification_prefs      Json?    @default("{\"email\":{\"newOrders\":true,\"disputes\":true,\"kycSubmissions\":true,\"payoutRequests\":true,\"systemAlerts\":true},\"push\":{\"newMessages\":true,\"orderUpdates\":true}}") @map("notification_prefs")
  created_at              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at              DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  
  mfa_secret              String?  @map("mfa_secret") @db.VarChar(255)
  mfa_enabled             Boolean  @default(false) @map("mfa_enabled")
  backup_codes            Json?    @map("backup_codes")

  role                    AdminRole? @relation(fields: [role_id], references: [id])
  activity_logs           AdminActivityLog[]

  @@map("admin_members")
}

model AdminActivityLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId         String?  @map("admin_id") @db.Uuid
  adminEmail      String?  @map("admin_email") @db.VarChar(255)
  action          String   @db.VarChar(100)
  resourceType    String?  @map("resource_type") @db.VarChar(50)
  resourceId      String?  @map("resource_id") @db.VarChar(255)
  oldValue        Json?    @map("old_value")
  newValue        Json?    @map("new_value")
  ipAddress       String?  @map("ip_address") @db.Inet
  userAgent       String?  @map("user_agent")
  status          String   @default("SUCCESS") @db.VarChar(20)
  failureReason   String?  @map("failure_reason")
  durationMs      Int?     @map("duration_ms")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  admin           AdminMember? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("admin_audit_logs")
}

model SuperAdmin {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String   @unique @db.VarChar(255)
  password_hash           String   @map("password_hash")
  name                    String   @db.VarChar(100)
  role                    String?  @default("superadmin") @db.VarChar(30)
  profile_image           String?  @map("profile_image")
  is_active               Boolean? @default(true) @map("is_active")
  last_login              DateTime? @map("last_login") @db.Timestamptz(6)
  last_login_ip           String?  @map("last_login_ip") @db.Inet
  login_attempts          Int?     @default(0) @map("login_attempts") @db.SmallInt
  locked_until            DateTime? @map("locked_until") @db.Timestamptz(6)
  current_session_token   String?  @map("current_session_token")
  created_at              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  mfa_secret              String?  @map("mfa_secret") @db.VarChar(255)
  mfa_enabled             Boolean  @default(false) @map("mfa_enabled")
  backup_codes            Json?    @map("backup_codes")

  @@map("super_admins")
}

model AdminSession {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId              String   @map("admin_id") @db.Uuid
  refreshTokenHash     String   @map("refresh_token_hash") @db.VarChar(255)
  deviceInfo           Json     @default("{}") @map("device_info")
  ipAddress            String   @map("ip_address") @db.Inet
  country              String?  @db.VarChar(3)
  city                 String?  @db.VarChar(100)
  isMfaVerified        Boolean  @default(false) @map("is_mfa_verified")
  lastActivityAt       DateTime @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  expiresAt            DateTime @map("expires_at") @db.Timestamptz(6)
  revokedAt            DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokeReason         String?  @map("revoke_reason") @db.VarChar(100)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([adminId])
  @@index([refreshTokenHash])
  @@map("admin_sessions")
}

// ============ ENUMS ============

enum NotificationType {
  SYSTEM
  SYNC_COMPLETE
  MESSAGE
  ORDER_UPDATE
  FOLLOW
  PROMOTION
  WELCOME
  MEDIA_READY
  MEDIA_FAILED
  STORY_EXPIRED
  STORY_READY
  STORY_DELETED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
}

enum Platform {
  IOS
  ANDROID
  WEB
}

enum UserRole {
  admin
  user
  suvix_user
}

enum AuthProvider {
  local
  google
}

enum RoleGroup {
  CLIENT
  PROVIDER
}

enum AvailabilityStatus {
  available
  busy
  away
}

enum PostType {
  IMAGE
  VIDEO
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaStatus {
  PENDING
  PROCESSING
  READY
  RETRYING
  FAILED
}

enum Visibility {
  PUBLIC
  PRIVATE
  FOLLOWERS
}
