{
  "expo": {
    "name": "SuviX",
    "slug": "suvix-mobile",
    "version": "1.0.0",
    "platforms": [
      "android",
      "ios"
    ],
    "orientation": "portrait",
    "icon": "./assets/appicon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.suvix.mobile"
    },
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "android": {
      "package": "in.suvix.mobile",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/appicon.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "statusBar": {
        "translucent": true
      }
    },
    "scheme": "in.suvix.mobile",
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#050509"
        }
      ],
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "usesCleartextTraffic": true,
            "newArchEnabled": false
          },
          "ios": {
            "newArchEnabled": false
          }
        }
      ],
      "expo-video",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SuviX to access your location to find nearby experts.",
          "isAndroidBackgroundEnabled": true
        }
      ],
      "@react-native-google-signin/google-signin",
      [
        "expo-notifications",
        {
          "icon": "./assets/appicon.png",
          "color": "#6C63FF",
          "defaultChannel": "suvix-default",
          "sounds": []
        }
      ],
      "expo-media-library"

    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c64d2453-3758-4664-a5b7-c6f07d60ca40"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c64d2453-3758-4664-a5b7-c6f07d60ca40"
    },
    "newArchEnabled": false,
    "owner": "suvin1515"
  }
}
