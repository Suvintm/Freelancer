  read_at         DateTime? @map("read_at") @db.Timestamptz(6)
  delivered       Boolean? @default(true) @map("delivered")
  delivered_at    DateTime? @default(now()) @map("delivered_at") @db.Timestamptz(6)
  is_edited       Boolean? @default(false) @map("is_edited")
  edited_at       DateTime? @map("edited_at") @db.Timestamptz(6)
  is_starred      Boolean? @default(false) @map("is_starred")
  is_deleted      Boolean? @default(false) @map("is_deleted")
  deleted_at      DateTime? @map("deleted_at") @db.Timestamptz(6)
  
  // Media fields
  media_url       String?  @map("media_url")
  media_filename  String?  @map("media_filename")
  media_size      BigInt?  @map("media_size")
  media_mimetype  String?  @map("media_mimetype")
  audio_duration  Float?   @map("audio_duration")

  // External links (Drive/Dropbox etc)
  external_link   Json?    @map("external_link")
  
  downloaded_by   String[] @default([]) @map("downloaded_by")
  
  created_at      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  order           Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  sender          User     @relation("MessageSender", fields: [sender_id], references: [id])
  receiver        User     @relation("MessageReceiver", fields: [receiver_id], references: [id])
  reply_to        Message? @relation("MessageReply", fields: [reply_to_id], references: [id])
  replies         Message[] @relation("MessageReply")

  @@index([order_id])
  @@index([sender_id])
  @@index([receiver_id])
  @@map("messages")
}




