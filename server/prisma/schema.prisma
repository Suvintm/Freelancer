// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}


// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  admin
  client
  editor
  pending
}

enum AuthProvider {
  local
  google
}

enum AvailabilityStatus {
  available
  busy
  away
  small_only
  EMPTY @map("")
}

enum KycStatus {
  not_started
  submitted
  pending
  under_review
  verified
  rejected
}

enum KycRole {
  client
  editor
}

enum KycAction {
  submitted
  verified
  rejected
  re_submitted
  auto_verified
  details_updated
}

enum OrderType {
  gig
  request
  brief
}

enum OrderStatus {
  pending_payment
  new
  awaiting_payment
  accepted
  in_progress
  submitted
  completed
  rejected
  cancelled
  disputed
  expired
}

enum PaymentStatus {
  pending
  processing
  escrow
  released
  refunded
  failed
}

enum EscrowStatus {
  none
  held
  released
  refunded
  disputed
}

enum DeliveryStatus {
  none
  pending_review
  changes_requested
  accepted
  completed
}

enum PayoutStatus {
  pending
  processing
  completed
  failed
}

enum ChatDisabledReason {
  none
  overdue
  refunded
  completed
  cancelled
}

enum DisputeResolution {
  released_to_editor
  refunded_to_client
  split
}

enum RefundStatus {
  initiated
  processing
  completed
  failed
  cancelled
  added_to_wallet
}

enum RefundReason {
  order_rejected
  order_cancelled
  editor_no_response
  client_request
  dispute_resolved
  payment_failed
  duplicate_payment
  admin_initiated
  overdue
  other
}

enum RefundMethod {
  original_payment
  bank_transfer
  upi
  wallet
}

enum WalletTxType {
  earning
  clearance
  withdrawal
  refund_credit
  platform_fee
  bonus
  reversal
  adjustment
}

enum WalletTxStatus {
  pending_clearance
  cleared
  withdrawn
  reversed
  cancelled
}

enum WithdrawalStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum SubFeature {
  profile_insights
  priority_listing
  analytics_pro
  all
}

enum SubStatus {
  trial
  active
  expired
  cancelled
  payment_pending
}

enum AdType {
  youtube
  instagram
  website
  app
  course
  event
  freelancer
  ecommerce
}

enum AdPlacement {
  home_banner
  reels_feed
  both
}

enum AdStatus {
  pending
  under_review
  approved
  rejected
  changes_requested
}

enum AdPaymentStatus {
  unpaid
  paid
  refunded
  waived
}

enum FollowRequestStatus {
  pending
  accepted
  rejected
}

enum BriefStatus {
  open
  in_review
  accepted
  completed
  expired
  cancelled
}

enum BriefCategory {
  video
  image
  thumbnail
  motion_graphics @map("motion-graphics")
  reel
  short
  other
}

enum ProposalStatus {
  pending
  shortlisted
  accepted
  rejected
  withdrawn
}

enum JobStatus {
  draft
  active
  paused
  closed
  filled
}

enum JobApplicationStatus {
  applied
  shortlisted
  round1
  round2
  round3
  hired
  rejected
  withdrawn
}

enum RatingStatus {
  published
  hidden
  flagged
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum BroadcastType {
  info
  warning
  success
  error
}

enum StoragePlanType {
  starter
  pro
  business
  unlimited
}

enum VisibilityLevel {
  city
  region
  country
}

enum PerformerRole {
  user
  admin
  system
}

enum InitiatorType {
  system
  admin
  client
  editor
}

enum Initiator2Type {
  system
  admin
  user
}

enum PaymentTxType {
  escrow_deposit
  escrow_release
  refund
  direct
}

enum PaymentTxStatus {
  pending
  processing
  completed
  failed
  refunded
}


// ==========================================
// CORE IDENTITY
// ==========================================

model User {
  id                        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username                  String?             @unique @db.VarChar(100)
  name                      String              @db.VarChar(100)
  email                     String              @unique @db.VarChar(255)
  password_hash             String?             @map("password_hash")
  role                      UserRole            @default(editor)
  auth_provider             AuthProvider?       @default(local) @map("auth_provider")
  google_id                 String?             @unique @map("google_id") @db.VarChar(255)
  profile_picture           String?             @default("") @map("profile_picture")
  bio                       String?             @default("")
  phone                     String?             @db.VarChar(20)
  is_phone_verified         Boolean?            @default(false) @map("is_phone_verified")
  country                   String?             @default("IN") @db.Char(2)
  currency                  String?             @default("INR") @db.VarChar(10)
  payment_gateway           String?             @default("razorpay") @map("payment_gateway") @db.VarChar(20)

  // Moderation
  is_banned                 Boolean?            @default(false) @map("is_banned")
  ban_reason                String?             @map("ban_reason")
  banned_at                 DateTime?           @map("banned_at") @db.Timestamptz(6)

  // Security
  password_reset_token      String?             @map("password_reset_token")
  password_reset_expires    DateTime?           @map("password_reset_expires") @db.Timestamptz(6)

  // Follow settings
  follow_manual_approval    Boolean?            @default(false) @map("follow_manual_approval")

  // Availability
  availability_status       AvailabilityStatus? @default(available) @map("availability_status")
  availability_busy_until   DateTime?           @map("availability_busy_until") @db.Timestamptz(6)
  availability_updated_at   DateTime?           @default(now()) @map("availability_updated_at") @db.Timestamptz(6)

  // KYC Lookup
  kyc_status                KycStatus?          @default(not_started) @map("kyc_status")
  kyc_tier                  Int?                @default(0) @map("kyc_tier") @db.SmallInt
  kyc_submitted_at          DateTime?           @map("kyc_submitted_at") @db.Timestamptz(6)
  kyc_verified_at           DateTime?           @map("kyc_verified_at") @db.Timestamptz(6)
  kyc_rejection_reason      String?             @map("kyc_rejection_reason")
  verification_method       String?             @default("not_verified") @map("verification_method") @db.VarChar(30)
  risk_level                RiskLevel?          @default(low) @map("risk_level")

  // Razorpay
  razorpay_contact_id       String?             @map("razorpay_contact_id") @db.VarChar(100)
  razorpay_fund_account_id  String?             @map("razorpay_fund_account_id") @db.VarChar(100)

  // Performance
  is_verified               Boolean?            @default(false) @map("is_verified")
  profile_completed         Boolean?            @default(false) @map("profile_completed")
  profile_completion_percent Int?                @default(0) @map("profile_completion_percent") @db.SmallInt

  // Consent
  consent_timestamp         DateTime?           @map("consent_timestamp") @db.Timestamptz(6)
  consent_ip_address        String?             @map("consent_ip_address") @db.Inet
  data_retention_expiry     DateTime?           @map("data_retention_expiry") @db.Timestamptz(6)

  created_at                DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at                DateTime?           @default(now()) @map("updated_at") @db.Timestamptz(6)

  // Relations
  profile                   UserProfile?
  wallet                    UserWallet?
  bank_details              UserBankDetails?
  fcm_tokens                UserFcmToken[]
  follows                   UserFollow[]        @relation("Follower")
  following                 UserFollow[]        @relation("Following")
  saved_editors             UserSavedEditor[]   @relation("User")
  editor_saves              UserSavedEditor[]   @relation("Editor")
  follow_requests_sent      FollowRequest[]     @relation("Sender")
  follow_requests_received  FollowRequest[]     @relation("Receiver")
  kyc_submissions           KycSubmission[]
  kyc_logs                  KycLog[]            @relation("KycUser")

  kyc_logs_performed        KycLog[]            @relation("KycPerformer")
  gigs                      Gig[]
  briefs                    Brief[]             @relation("Client")
  accepted_briefs           Brief[]             @relation("AcceptedEditor")
  brief_edits               BriefEditHistory[]
  proposals                 Proposal[]
  jobs_posted               Job[]
  job_views                 JobView[]
  job_applications          JobApplication[]
  job_app_changes           JobApplicationHistory[]
  orders_as_client          Order[]             @relation("Client")
  orders_as_editor          Order[]             @relation("Editor")
  deadline_extensions       OrderDeadlineExtension[]
  pins                      OrderPin[]
  payments_as_client        Payment[]           @relation("Client")
  payments_as_editor        Payment[]           @relation("Editor")
  refunds_as_client         Refund[]            @relation("Client")
  refunds_as_editor         Refund[]            @relation("Editor")
  refunds_initiated         Refund[]            @relation("InitiatedByUser")
  wallet_transactions       WalletTransaction[]
  withdrawal_requests       WithdrawalRequest[]
  subscriptions             Subscription[]
  storage_purchases         StoragePurchase[]
  ad_requests               AdRequest[]
  ratings_as_reviewer       Rating[]            @relation("Reviewer")
  ratings_as_reviewee       Rating[]            @relation("Reviewee")
  content_access_as_editor  ContentAccessLog[]  @relation("Editor")
  content_access_as_client  ContentAccessLog[]  @relation("Client")
  badges                    Badge[]
  location                  EditorLocation?
  sent_messages             Message[]           @relation("MessageSender")
  received_messages         Message[]           @relation("MessageReceiver")

  @@map("users")
}

model UserProfile {
  user_id                 String      @id @map("user_id") @db.Uuid
  about                   String?     @default("")
  skills                  String[]    @default([])
  languages               String[]    @default([])
  experience              String?     @default("") @db.VarChar(30)
  softwares               String[]    @default([])
  certifications          Json?       @default("[]")
  contact_email           String?     @default("") @map("contact_email") @db.VarChar(255)
  location_country        String?     @default("") @map("location_country") @db.VarChar(100)
  social_instagram        String?     @default("") @map("social_instagram")
  social_youtube          String?     @default("") @map("social_youtube")
  social_tiktok           String?     @default("") @map("social_tiktok")
  social_twitter          String?     @default("") @map("social_twitter")
  social_linkedin         String?     @default("") @map("social_linkedin")
  social_website          String?     @default("") @map("social_website")
  social_behance          String?     @default("") @map("social_behance")
  social_dribbble         String?     @default("") @map("social_dribbble")
  hourly_rate_min         Decimal?    @default(0) @map("hourly_rate_min") @db.Decimal(10, 2)
  hourly_rate_max         Decimal?    @default(0) @map("hourly_rate_max") @db.Decimal(10, 2)
  hourly_rate_currency    String?     @default("INR") @map("hourly_rate_currency") @db.VarChar(10)
  availability            String?     @default("") @db.VarChar(30)
  response_time           String?     @default("") @map("response_time") @db.VarChar(30)
  rating_stats            Json?       @default("{\"averageRating\":0,\"totalReviews\":0,\"qualityAvg\":0,\"communicationAvg\":0,\"speedAvg\":0}") @map("rating_stats")
  suvix_score             Json?       @default("{\"total\":0,\"tier\":\"newcomer\",\"isEligible\":false,\"completedOrders\":0,\"components\":{\"deadline\":0,\"ratings\":0,\"completion\":0,\"response\":0,\"revisions\":0,\"experience\":0}}") @map("suvix_score")
  ai_profile              Json?       @default("{\"aiKeywords\":[],\"aiDescription\":\"\",\"videoStyles\":[],\"softwareProficiency\":{}}") @map("ai_profile")
  profile_views           Int?        @default(0) @map("profile_views")
  updated_at              DateTime?   @default(now()) @map("updated_at") @db.Timestamptz(6)

  user                    User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserWallet {
  user_id             String      @id @map("user_id") @db.Uuid
  wallet_balance      Decimal?    @default(0.00) @map("wallet_balance") @db.Decimal(15, 2)
  pending_balance     Decimal?    @default(0.00) @map("pending_balance") @db.Decimal(15, 2)
  lifetime_earnings   Decimal?    @default(0.00) @map("lifetime_earnings") @db.Decimal(15, 2)
  total_withdrawn     Decimal?    @default(0.00) @map("total_withdrawn") @db.Decimal(15, 2)
  updated_at          DateTime?   @default(now()) @map("updated_at") @db.Timestamptz(6)

  user                User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_wallets")
}

model UserBankDetails {
  user_id                     String      @id @map("user_id") @db.Uuid
  account_holder_name         String?     @map("account_holder_name") @db.VarChar(200)
  account_number_enc          String?     @map("account_number_enc")
  account_number_masked       String?     @map("account_number_masked") @db.VarChar(20)
  account_type                String?     @default("savings") @map("account_type") @db.VarChar(20)
  ifsc_code                   String?     @map("ifsc_code") @db.VarChar(15)
  bank_name                   String?     @map("bank_name") @db.VarChar(100)
  pan_number_enc              String?     @map("pan_number_enc")
  pan_number_masked           String?     @map("pan_number_masked") @db.VarChar(15)
  upi_id                      String?     @map("upi_id") @db.VarChar(100)
  gstin                       String?     @map("gstin") @db.VarChar(20)
  address_street              String?     @map("address_street")
  address_city                String?     @map("address_city") @db.VarChar(100)
  address_state               String?     @map("address_state") @db.VarChar(100)
  address_postal_code         String?     @map("address_postal_code") @db.VarChar(20)
  address_country             String?     @default("IN") @map("address_country") @db.Char(2)
  updated_at                  DateTime?   @default(now()) @map("updated_at") @db.Timestamptz(6)

  user                        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_bank_details")
}

model UserFcmToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @map("user_id") @db.Uuid
  token       String   @unique
  created_at  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_fcm_tokens")
}

model UserFollow {
  follower_id     String   @map("follower_id") @db.Uuid
  following_id    String   @map("following_id") @db.Uuid
  created_at      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  follower        User     @relation("Follower", fields: [follower_id], references: [id], onDelete: Cascade)
  following       User     @relation("Following", fields: [following_id], references: [id], onDelete: Cascade)

  @@id([follower_id, following_id])
  @@map("user_follows")
}

model UserSavedEditor {
  user_id     String   @map("user_id") @db.Uuid
  editor_id   String   @map("editor_id") @db.Uuid
  created_at  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user        User     @relation("User", fields: [user_id], references: [id], onDelete: Cascade)
  editor      User     @relation("Editor", fields: [editor_id], references: [id], onDelete: Cascade)

  @@id([user_id, editor_id])
  @@map("user_saved_editors")
}

model FollowRequest {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id       String              @map("sender_id") @db.Uuid
  receiver_id     String              @map("receiver_id") @db.Uuid
  status          FollowRequestStatus @default(pending)
  created_at      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  sender          User                @relation("Sender", fields: [sender_id], references: [id], onDelete: Cascade)
  receiver        User                @relation("Receiver", fields: [receiver_id], references: [id], onDelete: Cascade)

  @@unique([sender_id, receiver_id])
  @@map("follow_requests")
}

// ==========================================
// ADMIN & ROLES
// ==========================================

model AdminRole {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(100)
  value           String   @unique @db.VarChar(50)
  description     String?  @default("")
  color           String?  @default("#1d4ed8") @db.VarChar(20)
  permissions     Json     @default("{}")
  is_active       Boolean? @default(true) @map("is_active")
  is_system       Boolean? @default(false) @map("is_system")
  member_count    Int?     @default(0) @map("member_count")
  created_at      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  members         AdminMember[]

  @@map("admin_roles")
}

model AdminMember {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String   @unique @db.VarChar(255)
  password_hash           String   @map("password_hash")
  name                    String   @db.VarChar(100)
  role_id                 String?  @map("role_id") @db.Uuid
  role_value              String?  @default("admin") @map("role_value") @db.VarChar(50)
  profile_image           String?  @map("profile_image")
  permissions             Json?    @default("{}")
  is_active               Boolean? @default(true) @map("is_active")
  last_login              DateTime? @map("last_login") @db.Timestamptz(6)
  last_login_ip           String?  @map("last_login_ip") @db.Inet
  login_attempts          Int?     @default(0) @map("login_attempts") @db.SmallInt
  locked_until            DateTime? @map("locked_until") @db.Timestamptz(6)
  current_session_token   String?  @map("current_session_token")
  password_reset_token    String?  @map("password_reset_token")
  password_reset_expires  DateTime? @map("password_reset_expires") @db.Timestamptz(6)
  password_changed_at     DateTime? @map("password_changed_at") @db.Timestamptz(6)
  notification_prefs      Json?    @default("{\"email\":{\"newOrders\":true,\"disputes\":true,\"kycSubmissions\":true,\"payoutRequests\":true,\"systemAlerts\":true},\"push\":{\"newMessages\":true,\"orderUpdates\":true}}") @map("notification_prefs")
  created_at              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at              DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  role                    AdminRole? @relation(fields: [role_id], references: [id])
  activity_logs           AdminActivityLog[]
  kyc_verified            KycSubmission[]
  ad_requests             AdRequest[] @relation("AdminReviewer")
  order_notes             OrderAdminNote[]

  @@map("admin_members")
}

model AdminActivityLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_id    String   @map("admin_id") @db.Uuid
  action      String
  details     String?
  ip          String?  @db.Inet
  created_at  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  admin       AdminMember @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id])
  @@index([created_at(sort: Desc)])
  @@map("admin_activity_log")
}

model SuperAdmin {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String   @unique @db.VarChar(255)
  password_hash           String   @map("password_hash")
  name                    String   @db.VarChar(100)
  role                    String?  @default("superadmin") @db.VarChar(30)
  profile_image           String?  @map("profile_image")
  is_active               Boolean? @default(true) @map("is_active")
  last_login              DateTime? @map("last_login") @db.Timestamptz(6)
  last_login_ip           String?  @map("last_login_ip") @db.Inet
  login_attempts          Int?     @default(0) @map("login_attempts") @db.SmallInt
  locked_until            DateTime? @map("locked_until") @db.Timestamptz(6)
  current_session_token   String?  @map("current_session_token")
  created_at              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("super_admins")
}

// ==========================================
// KYC
// ==========================================

model KycSubmission {
  id                          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                     String      @map("user_id") @db.Uuid
  user_role                   KycRole     @map("user_role")
  full_name                   String      @map("full_name") @db.VarChar(100)
  phone                       String      @db.VarChar(15)
  email                       String      @db.VarChar(255)
  address_street              String?     @map("address_street")
  address_city                String?     @map("address_city") @db.VarChar(100)
  address_state               String?     @map("address_state") @db.VarChar(100)
  address_postal_code         String?     @map("address_postal_code") @db.VarChar(20)
  address_country             String?     @default("IN") @map("address_country") @db.Char(2)
  gstin                       String?     @db.VarChar(20)
  bank_account_number_enc     String?     @map("bank_account_number_enc")
  bank_account_number_masked  String?     @map("bank_account_number_masked") @db.VarChar(20)
  ifsc_code                   String?     @map("ifsc_code") @db.VarChar(15)
  bank_name                   String?     @map("bank_name") @db.VarChar(100)
  account_holder_name         String?     @map("account_holder_name") @db.VarChar(200)
  account_type                String?     @default("savings") @map("account_type") @db.VarChar(20)
  upi_id                      String?     @map("upi_id") @db.VarChar(100)
  pan_number_enc              String?     @map("pan_number_enc")
  pan_number_masked           String?     @map("pan_number_masked") @db.VarChar(15)
  preferred_refund_method     String?     @default("original_payment") @map("preferred_refund_method") @db.VarChar(30)
  status                      KycStatus   @default(not_started)
  verified_at                 DateTime?   @map("verified_at") @db.Timestamptz(6)
  verified_by                 String?     @map("verified_by") @db.Uuid
  rejection_reason            String?     @map("rejection_reason")
  auto_verification_result    Json?       @default("{}") @map("auto_verification_result")
  risk_flags                  String[]    @default([]) @map("risk_flags")
  ip_address                  String?     @map("ip_address") @db.Inet
  user_agent                  String?     @map("user_agent")
  terms_accepted              Boolean?    @default(false) @map("terms_accepted")
  terms_accepted_at           DateTime?   @map("terms_accepted_at") @db.Timestamptz(6)
  submitted_at                DateTime?   @map("submitted_at") @db.Timestamptz(6)
  created_at                  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at                  DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)

  user                        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  admin                       AdminMember? @relation(fields: [verified_by], references: [id])
  documents                   KycDocument[]

  @@unique([user_id, user_role])
  @@map("kyc_submissions")
}

model KycDocument {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kyc_id      String   @map("kyc_id") @db.Uuid
  doc_type    String   @map("doc_type") @db.VarChar(30)
  url         String
  verified    Boolean? @default(false)
  uploaded_at DateTime? @default(now()) @map("uploaded_at") @db.Timestamptz(6)

  kyc         KycSubmission @relation(fields: [kyc_id], references: [id], onDelete: Cascade)

  @@map("kyc_documents")
}

model KycLog {
