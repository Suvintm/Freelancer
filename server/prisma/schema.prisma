// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// NEW PRODUCTION SCHEMA (REFINED ROLE SYSTEM)
// ==========================================

enum UserRole {
  admin
  user
  suvix_user
}

enum AuthProvider {
  local
  google
}

enum RoleGroup {
  CLIENT
  PROVIDER
}

enum AvailabilityStatus {
  available
  busy
  away
}

model User {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String        @unique @db.VarChar(255)
  password_hash   String?       @map("password_hash")
  role            UserRole      @default(suvix_user)
  auth_provider   AuthProvider? @default(local) @map("auth_provider")
  google_id       String?       @unique @map("google_id") @db.VarChar(255)
  is_verified     Boolean       @default(false) @map("is_verified")
  is_banned       Boolean       @default(false) @map("is_banned")
  is_onboarded    Boolean       @default(false) @map("is_onboarded")
  created_at      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  // Relations
  profile         UserProfile?
  follows         UserFollow[]  @relation("Follower")
  following       UserFollow[]  @relation("Following")
  sent_messages   Message[]     @relation("MessageSender")
  received_messages Message[]    @relation("MessageReceiver")

  @@map("users")
}

model UserProfile {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String        @unique @map("user_id") @db.Uuid
  username          String        @unique @db.VarChar(100)
  name              String        @db.VarChar(100)
  profile_picture   String?       @map("profile_picture")
  bio               String?       @db.Text
  mother_tongue     String?       @map("mother_tongue") @db.VarChar(50)
  auth_provider     AuthProvider? @default(local) @map("auth_provider")
  
  // Location
  location_city     String?       @map("location_city") @db.VarChar(100)
  location_state    String?       @map("location_state") @db.VarChar(100)
  location_country  String?       @default("India") @map("location_country") @db.VarChar(100)
  
  // Contact
  phone             String?       @db.VarChar(20)
  is_phone_verified Boolean       @default(false) @map("is_phone_verified")
  
  // Status
  availability      AvailabilityStatus @default(available)
  
  // Professional Identity (Locked to ONE category)
  categoryId        String        @map("role_category_id") @db.Uuid
  
  created_at        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at        DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  // Relations
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          RoleCategory  @relation(fields: [categoryId], references: [id])
  roles             UserRoleMapping[]

  @@map("user_profiles")
}

model UserFollow {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followerId      String   @map("follower_id") @db.Uuid
  followingId     String   @map("following_id") @db.Uuid
  created_at      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  follower        User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following       User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("user_follows")
}

model RoleCategory {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String        @db.VarChar(100)
  slug            String        @unique @db.VarChar(100)
  icon            String?       @db.VarChar(50)
  roleGroup       RoleGroup     @default(PROVIDER) @map("role_group")
  description     String?       @db.Text
  info            String?       @db.Text
  
  subCategories   RoleSubCategory[]
  profiles        UserProfile[]

  @@map("role_categories")
}

model RoleSubCategory {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleCategoryId  String        @map("role_category_id") @db.Uuid
  name            String        @db.VarChar(100)
  slug            String        @db.VarChar(100)
  
  category        RoleCategory  @relation(fields: [roleCategoryId], references: [id], onDelete: Cascade)
  userRoles       UserRoleMapping[]

  @@unique([roleCategoryId, slug])
  @@map("role_sub_categories")
}

model UserRoleMapping {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId          String          @map("profile_id") @db.Uuid
  roleSubCategoryId  String          @map("role_sub_category_id") @db.Uuid

  profile            UserProfile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subCategory        RoleSubCategory @relation(fields: [roleSubCategoryId], references: [id], onDelete: Cascade)

  @@unique([profileId, roleSubCategoryId])
  @@map("user_role_mappings")
}

model Message {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id       String   @map("sender_id") @db.Uuid
  receiver_id     String   @map("receiver_id") @db.Uuid
  type            String   @default("text") @db.VarChar(20)
  content         String   @db.Text
  is_read         Boolean  @default(false) @map("is_read")
  created_at      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  sender          User     @relation("MessageSender", fields: [sender_id], references: [id])
  receiver        User     @relation("MessageReceiver", fields: [receiver_id], references: [id])

  @@index([sender_id])
  @@index([receiver_id])
  @@map("messages")
}
