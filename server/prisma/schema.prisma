model Order {
  id                          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_number                String          @unique @map("order_number") @db.VarChar(50)
  type                        OrderType
  gig_id                      String?         @map("gig_id") @db.Uuid
  brief_id                    String?         @map("brief_id") @db.Uuid
  client_id                   String          @map("client_id") @db.Uuid
  editor_id                   String          @map("editor_id") @db.Uuid
  title                       String          @db.VarChar(150)
  description                 String
  deadline                    DateTime        @db.Timestamptz(6)

  // Pricing
  amount                      Decimal         @db.Decimal(12, 2)
  currency                    String?         @default("INR") @db.Char(3)
  platform_fee_percentage     Decimal?        @default(0) @map("platform_fee_percentage") @db.Decimal(5, 2)
  platform_fee                Decimal?        @default(0) @map("platform_fee") @db.Decimal(12, 2)
  editor_earning              Decimal?        @default(0) @map("editor_earning") @db.Decimal(12, 2)

  // Statuses
  status                      OrderStatus     @default(new)
  payment_status              PaymentStatus?  @default(pending) @map("payment_status")
  escrow_status               EscrowStatus?   @default(none) @map("escrow_status")
  delivery_status             DeliveryStatus? @default(none) @map("delivery_status")
  payout_status               PayoutStatus?   @default(pending) @map("payout_status")

  // Payment gateway
  payment_gateway             String?         @default("none") @map("payment_gateway") @db.VarChar(20)
  payment_expires_at          DateTime?       @map("payment_expires_at") @db.Timestamptz(6)
  razorpay_order_id           String?         @map("razorpay_order_id") @db.VarChar(100)
  razorpay_payment_id         String?         @map("razorpay_payment_id") @db.VarChar(100)
  razorpay_signature          String?         @map("razorpay_signature") @db.VarChar(200)
  razorpay_payout_id          String?         @map("razorpay_payout_id") @db.VarChar(100)
  stripe_payment_intent_id    String?         @map("stripe_payment_intent_id") @db.VarChar(200)
  stripe_transfer_id          String?         @map("stripe_transfer_id") @db.VarChar(200)

  // Escrow
  escrow_held_at              DateTime?       @map("escrow_held_at") @db.Timestamptz(6)
  escrow_released_at          DateTime?       @map("escrow_released_at") @db.Timestamptz(6)

  // Payout
  payout_amount               Decimal?        @default(0) @map("payout_amount") @db.Decimal(12, 2)
  payout_completed_at         DateTime?       @map("payout_completed_at") @db.Timestamptz(6)

  // Refund
  refund_id                   String?         @map("refund_id") @db.VarChar(100)
  refund_amount               Decimal?        @default(0) @map("refund_amount") @db.Decimal(12, 2)
  refunded_at                 DateTime?       @map("refunded_at") @db.Timestamptz(6)
  refund_reason               String?         @map("refund_reason")

  // Cancellation & dispute
  cancellation_reason         String?         @map("cancellation_reason")
  dispute_reason              String?         @map("dispute_reason")
  disputed_at                 DateTime?       @map("disputed_at") @db.Timestamptz(6)
  dispute_resolved_at         DateTime?       @map("dispute_resolved_at") @db.Timestamptz(6)
  dispute_resolution          DisputeResolution? @map("dispute_resolution")

  // Tracking timestamps
  accepted_at                 DateTime?       @map("accepted_at") @db.Timestamptz(6)
  started_at                  DateTime?       @map("started_at") @db.Timestamptz(6)
  submitted_at                DateTime?       @map("submitted_at") @db.Timestamptz(6)
  completed_at                DateTime?       @map("completed_at") @db.Timestamptz(6)
  cancelled_at                DateTime?       @map("cancelled_at") @db.Timestamptz(6)

  // Auto-release
  auto_release_scheduled_at   DateTime?       @map("auto_release_scheduled_at") @db.Timestamptz(6)
  auto_released               Boolean?        @default(false) @map("auto_released")

  // Delivery
  final_delivery_message_id   String?         @map("final_delivery_message_id")

  // Scoring
  is_rated                    Boolean?        @default(false) @map("is_rated")
  delivery_days_early_or_late Int?            @map("delivery_days_early_or_late")
  delivery_calculated_at      DateTime?       @map("delivery_calculated_at") @db.Timestamptz(6)
  revision_count              Int?            @default(0) @map("revision_count")

  // Overdue
  is_overdue                  Boolean?        @default(false) @map("is_overdue")
  overdue_at                  DateTime?       @map("overdue_at") @db.Timestamptz(6)
  grace_ends_at               DateTime?       @map("grace_ends_at") @db.Timestamptz(6)
  overdue_refunded            Boolean?        @default(false) @map("overdue_refunded")
  overdue_refunded_at         DateTime?       @map("overdue_refunded_at") @db.Timestamptz(6)
  pending_client_decision     Boolean?        @default(false) @map("pending_client_decision")
  deadline_extension_count    Int?            @default(0) @map("deadline_extension_count") @db.SmallInt

  // Chat
  chat_disabled               Boolean?        @default(false) @map("chat_disabled")
  chat_disabled_reason        ChatDisabledReason? @default(none) @map("chat_disabled_reason")

  created_at                  DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at                  DateTime?       @default(now()) @map("updated_at") @db.Timestamptz(6)

  client                      User            @relation("Client", fields: [client_id], references: [id])
  editor                      User            @relation("Editor", fields: [editor_id], references: [id])
  gig                         Gig?            @relation(fields: [gig_id], references: [id])
  brief                       Brief?          @relation(fields: [brief_id], references: [id])
  deadline_extensions         OrderDeadlineExtension[]
  pins                        OrderPin[]
  admin_notes                 OrderAdminNote[]
  payments                    Payment[]
  refunds                     Refund[]
  wallet_transactions         WalletTransaction[]
  ratings                     Rating?
  content_access_logs         ContentAccessLog[]
  messages                    Message[]

  @@index([client_id])

  @@index([editor_id])
  @@index([status])
  @@index([payment_status])
  @@index([razorpay_order_id])
  @@map("orders")
}

